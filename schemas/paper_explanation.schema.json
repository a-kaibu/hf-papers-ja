{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaperExplanation",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "explanation": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["title", "summary", "explanation", "tags"]
}
